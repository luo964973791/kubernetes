# ============ 日志函数 ============
green() {
    echo -e "\e[01;32m$(date "+%Y-%m-%d %H:%M:%S") [INFO] $*\e[01;00m"
}

red() {
    echo -e "\e[01;31m$(date "+%Y-%m-%d %H:%M:%S") [ERROR] $*\e[01;00m"
}

yellow() {
    echo -e "\e[01;33m$(date "+%Y-%m-%d %H:%M:%S") [WARNNING] $*\e[01;00m"
}

# ============ 核心通用抽象 ============

# 通用函数：获取资源的 namespace 和名称
# 参数: _find_resource <resource_type> <keyword>
# 输出全局变量: ns, resource_name
_find_resource() {
    local resource_type=$1
    local keyword=$2
    
    if [ -z "$resource_type" ] || [ -z "$keyword" ]; then
        red "错误: 缺少参数"
        return 1
    fi
    
    local info=$(kubectl get "$resource_type" -A 2>/dev/null | grep "$keyword" | head -n 1)
    
    if [ -z "$info" ]; then
        red "未找到包含 [$keyword] 的 $resource_type"
        return 1
    fi
    
    ns=$(echo "$info" | awk '{print $1}')
    resource_name=$(echo "$info" | awk '{print $2}')
}

# 通用函数：获取资源数据并显示
# 参数: _show_resource <resource_type> <name> <namespace> [decode]
# decode=true 时进行 base64 解码（用于 secret）
_show_resource() {
    local resource_type=$1
    local name=$2
    local namespace=$3
    local decode=${4:-false}
    
    local tpl
    if [ "$decode" = "true" ]; then
        tpl='{{range $k,$v := .data}}{{printf "%s=%s\n" $k ($v|base64decode)}}{{end}}'
    else
        tpl='{{range $k,$v := .data}}{{printf "%s=%s\n" $k $v}}{{end}}'
    fi
    
    local out=$(kubectl get "$resource_type" "$name" -n "$namespace" -o go-template="$tpl" 2>/dev/null)
    
    if [ -z "$out" ]; then
        yellow "$resource_type 为空或无 data 字段，显示完整 YAML:"
        kubectl get "$resource_type" "$name" -n "$namespace" -o yaml
    fi
    #echo "$out" | sed 's/^/  /'
    echo "$out"
}

# 检测 shell
_shell() {
    kubectl exec "$1" -n "$2" -- test -f /bin/bash &>/dev/null && echo "/bin/bash" || echo "/bin/sh"
}

# ============ 业务函数 ============

kdel() {
    if [ -z "$1" ]; then
        echo "使用方法: kdel <pod关键字>"
        return 1
    fi
    
    export -f green
    kubectl get pod -A | grep "$1" | awk '{print $1, $2}' | xargs -L 1 sh -c '
        if [ -n "$1" ] && [ -n "$2" ]; then
            green "正在删除命名空间 [ $1 ] 下的 Pod: $2 ..."
            kubectl delete pod "$2" -n "$1" --grace-period=0 
        fi
    ' _
}

kg() {
    if [ -z "$1" ]; then
        echo "使用方法: kg <关键字>"
        return 1
    fi
    
    kubectl get pod -A | head -n 1
    kubectl get pod -A | tail -n +2 | grep --color=always "$1"
}

pod_status() {
    local header=$(kubectl get pod -A | head -n 1)
    local errors=$(kubectl get pod -A | grep -vE "([1-9])/\1|Completed|NAME")
    
    if [ -z "$errors" ]; then
        green "🎉 所有 Pod 状态正常！"
    else
        red "$header"
        red "$errors"
    fi
}

kports() {
    if [ -z "$1" ]; then
        red "使用方法: kports <pod名称关键字>"
        return 1
    fi
    
    _find_resource "pod" "$1" || return 1
    kubectl debug "$resource_name" -n "$ns" -it --image=nicolaka/netshoot --image-pull-policy=IfNotPresent
}

kgcm() {
    if [ -z "$1" ]; then
        yellow "使用方法: kgcm <configmap-name>"
        return 1
    fi
    
    _find_resource "configmap" "$1" || return 1
    green "找到 ConfigMap: $resource_name (命名空间: $ns)"
    _show_resource "configmap" "$resource_name" "$ns" false
}

ksct() {
    if [ -z "$1" ]; then
        yellow "使用方法: ksct <secret-name-keyword>"
        return 1
    fi
    
    _find_resource "secret" "$1" || return 1
    green "找到 Secret: $resource_name (命名空间: $ns)"
    _show_resource "secret" "$resource_name" "$ns" true
}

kexec() {
    if [ -z "$1" ]; then
        red "使用方法: kexec <pod名称关键字>"
        return 1
    fi
    
    _find_resource "pod" "$1" || return 1
    
    local shell=$(_shell "$resource_name" "$ns")
    green "检测到 shell: $shell，正在进入容器..."
    kubectl exec -it "$resource_name" -n "$ns" -- "$shell"
}
